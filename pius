  <script>
    // ---------- BASIC SETUP (loading, progress, fade, modals, emailjs placeholders) ----------
    window.addEventListener('load', () => { document.getElementById('loading-screen').style.opacity = '0'; document.getElementById('loading-screen').style.visibility = 'hidden'; });
    window.addEventListener('scroll', () => { let h = document.documentElement, b = document.body, st = 'scrollTop', sh = 'scrollHeight'; let percent = (h[st]||b[st]) / ((h[sh]||b[sh]) - h.clientHeight) * 100; document.getElementById('progress-bar').style.width = percent + '%'; });
    const faders = document.querySelectorAll('.fade-in'); new IntersectionObserver(entries => { entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')); }, {threshold:0.2}).observe(faders[0]);
    // email modal
    const modal = document.getElementById('emailModal'); const emailIcons = document.querySelectorAll('#emailIcon, #emailIconFooter'); const closeModal = document.getElementById('closeEmailModal'); emailIcons.forEach(icon => icon.addEventListener('click', (e) => { e.preventDefault(); modal.classList.add('active'); })); closeModal.addEventListener('click', () => modal.classList.remove('active')); window.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('active'); });
