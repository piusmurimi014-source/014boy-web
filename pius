    document.getElementById('emailPopupForm')?.addEventListener('submit', function(e) { e.preventDefault(); alert('EmailJS needs your service ID. Using fallback.'); window.location.href = `mailto:piusartist0@gmail.com?subject=Message from ${this.name.value}&body=${this.message.value}%0A%0AFrom: ${this.email.value}`; });
    document.getElementById('bookingForm')?.addEventListener('submit', function(e) { e.preventDefault(); alert('Booking form would send email. For now, use direct contact.'); document.getElementById('bookingSuccess').style.display = 'block'; setTimeout(()=>document.getElementById('bookingSuccess').style.display='none',3000); });
    document.getElementById('newsletterForm')?.addEventListener('submit', (e) => { e.preventDefault(); document.getElementById('newsletterSuccess').style.display='block'; e.target.reset(); setTimeout(()=>document.getElementById('newsletterSuccess').style.display='none',3000); });
    // lightbox
    const galleryItems = document.querySelectorAll('.gallery-item'); const lightbox = document.getElementById('lightbox'); const lightboxImg = document.getElementById('lightboxImg'); const closeLightbox = document.getElementById('closeLightbox'); galleryItems.forEach(item => { item.addEventListener('click', () => { lightboxImg.src = item.querySelector('img').src; lightbox.classList.add('active'); }); }); closeLightbox.addEventListener('click', () => lightbox.classList.remove('active')); lightbox.addEventListener('click', (e) => { if (e.target === lightbox) lightbox.classList.remove('active'); });

    // ---------- UPGRADED AI CHAT with memory, language detection, personality ----------
    const chatToggle = document.getElementById('chatToggle');
    const chatWidget = document.getElementById('chatWidget');
    const closeChat = document.getElementById('closeChat');
    const openChatAI = document.getElementById('openChatAI');
    const sendChat = document.getElementById('sendChat');
    const chatInput = document.getElementById('chatInput');
    const chatMessages = document.getElementById('chatMessages');

    // Conversation memory
    let memory = {
      userName: null,
      lastTopic: null,
      waitingFor: null,
      step: 0
    };

    function toggleChat(show) { if (show) chatWidget.classList.add('open'); else chatWidget.classList.remove('open'); }
    chatToggle.addEventListener('click', () => toggleChat(!chatWidget.classList.contains('open')));
    closeChat.addEventListener('click', () => toggleChat(false));
    openChatAI.addEventListener('click', (e) => { e.preventDefault(); toggleChat(true); });

    // Enhanced language detection (English, Swahili, Sheng)
    function detectLanguage(text) {
      const lower = text.toLowerCase();
      // Strong Swahili indicators
      const swaWords = ['mambo', 'vipi', 'habari', 'asante', 'tafadhali', 'sawa', 'ndio', 'hapana', 'poa', 'safi', 'karibu', 'shwari', 'mbaya', 'lala', 'kuja', 'nzuri', 'sema', 'noma', 'kitu', 'bado', 'mjini', 'wapi', 'nini', 'yeye', 'wewe', 'yangu', 'yetu', 'kwa', 'kweli', 'kumbe', 'sijui', 'najua', 'ata', 'lakini', 'ila', 'sana', 'kidogo', 'mzigo', 'digrii'];
      let swaCount = swaWords.filter(w => lower.includes(w)).length;
      // Sheng usually mixes English and Swahili, we can detect if both present
      const engWords = ['the', 'you', 'and', 'for', 'this', 'that', 'with', 'have', 'from', 'what', 'where', 'who', 'how', 'why', 'when', 'which', 'there', 'here'];
      let engCount = engWords.filter(w => lower.includes(w)).length;
      if (swaCount > 2 && engCount < 2) return 'swahili';
      if (swaCount > 0 && engCount > 0) return 'sheng';
      return 'english';
    }

    // Responses vary to avoid repetition
    const greetingReplies = {
      english: ["Hey! What's good?", "Hello there! How can I help?", "Hi! Ready to assist you.", "Hey! How's it going?"],
      swahili: ["Mambo vipi?", "Niaje! Unaendeleaje?", "Sema! Niko hapa kukusaidia.", "Habari yako?"],
      sheng: ["Mambo! Uko poa?", "Niaje! Uko fiti?", "Sema ndio!"]
    };

    function getRandom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    // Core intelligent reply function
    function getBotReply(userMsg) {
      const msg = userMsg.trim();
      if (!msg) return "Say something, fam! 😄";

      const lang = detectLanguage(msg);
      const lower = msg.toLowerCase();

      // ---- MEMORY: store name if user introduces ----
      const nameMatch = msg.match(/(?:my name is|i'?m|call me|naitwa|ninaitwa|jina langu|it's)\s+([a-zA-Z]+)/i);
      if (nameMatch && !memory.userName) {
        memory.userName = nameMatch[1];
        if (lang === 'swahili') return `Poa ${memory.userName}! Naitwa 014 AI. Niko hapa kukusaidia. 😎`;
        else if (lang === 'sheng') return `Sawa ${memory.userName}! I'm 014 AI, unasemaje?`;
        else return `Nice to meet you, ${memory.userName}! I'm 014 AI, how can I help?`;
      }

      // ---- GREETINGS ----
      if (lower.match(/\b(hi|hello|hey|mambo|niaje|sema|habari|poa|safi)\b/)) {
        if (memory.userName) return `Hey ${memory.userName}! ${getRandom(greetingReplies[lang])}`;
        else return getRandom(greetingReplies[lang]);
      }

      // ---- HOW ARE YOU? ----
      if (lower.match(/\b(how are you|how you doing|poa|safi|uko poa|habari gani|vipi|namna|maisha|life)\b/)) {
        if (lang === 'swahili') return "Poa sana! Niko fiti, na wewe?";
        if (lang === 'sheng') return "Poa, niko fiti! Uko poa?";
        return "I'm doing great! Ready to help you out. What about you?";
      }

      // ---- THANKS ----
      if (lower.match(/\b(thanks|thank you|asante|ahsante)\b/)) {
        if (lang === 'swahili') return "Karibu sana! 😊";
        if (lang === 'sheng') return "Karibu kabisa!";
        return "You're welcome! Always here to help.";
      }

      // ---- ABOUT 014BOY ----
      if (lower.includes('who is 014') || lower.includes('about 014') || lower.includes('tell me about 014boy') || lower.includes('014boy ni nani')) {
        return "014Boy is Embu's smartest digital comedian! He creates funny, tech-savvy content, does MC gigs, brand promotions, and runs ICT systems. He's all about intelligent comedy with a Kenyan vibe. Want to see his latest video or book him?";
      }

      // ---- SKILLS / WHAT CAN YOU DO ----
      if (lower.includes('what can you do') || lower.includes('help me') || lower.includes('skills') || lower.includes('uwezo wako')) {
        return "I can answer questions about 014Boy, guide you through booking, share social links, chat about random topics, and even help with general knowledge. Just ask! 😎";
      }

      // ---- BOOKING ----
      if (lower.includes('book') || lower.includes('hire') || lower.includes('event') || lower.includes('booking') || lower.includes('kazi') || lower.includes('show') || lower.includes('mc') || lower.includes('host')) {
        memory.lastTopic = 'booking';
        return "You can book 014Boy for events, MC gigs, campus shows, brand promotions, weddings, and more! Just head to the 'Book' section on this website and fill out the form. Or you can message directly on WhatsApp wa.me/254742544885. Would you like the WhatsApp link? 📅🎤";
      }

      // ---- SOCIAL LINKS ----
      if (lower.includes('social') || lower.includes('tiktok') || lower.includes('facebook') || lower.includes('youtube') || lower.includes('instagram') || lower.includes('media')) {
        return "Here are 014Boy's official handles:\n• TikTok: @014.boyz (https://tiktok.com/@014.boyz)\n• Facebook: Pius014 (https://www.facebook.com/Pius014)\n• YouTube: @014Boyz (http://www.youtube.com/@014Boyz)\n• Email: piusartist0@gmail.com\n• WhatsApp: wa.me/254742544885\nAnything else you need?";
      }

      // ---- VIDEOS / CONTENT ----
      if (lower.includes('video') || lower.includes('latest') || lower.includes('skit') || lower.includes('comedy') || lower.includes('content') || lower.includes('youtube')) {
        return "014Boy posts fresh comedy skits and tech content on YouTube and TikTok. You can check out his YouTube channel: http://www.youtube.com/@014Boyz. Want me to recommend a specific video?";
      }

      // ---- CONTACT (direct) ----
      if (lower.includes('contact') || lower.includes('email') || lower.includes('whatsapp') || lower.includes('phone') || lower.includes('number') || lower.includes('reach')) {
        return "You can reach 014Boy via:\n📧 Email: piusartist0@gmail.com\n📱 WhatsApp: wa.me/254742544885\n🐦 TikTok/IG: @014.boyz\nI can also help with booking if you need!";
      }

      // ---- FALLBACK for general knowledge / anything else (intelligent) ----
      // Provide a helpful, conversational fallback that simulates intelligence
      // We can also have canned responses for common questions (time, weather, etc.)
      if (lower.includes('time') || lower.includes('saa ngapi') || lower.includes('time now')) {
        return "I don't have real-time clock access, but you can check your device's time! 😄 Anything else I can help with?";
      }
      if (lower.includes('weather') || lower.includes('hali ya hewa')) {
        return "I can't fetch live weather right now, but it's always a good day to laugh! Check your local forecast. Need something else?";
      }
      if (lower.includes('old') || lower.includes('age') || lower.includes('umri')) {
        return "014Boy is a young, energetic creative – age is just a number when you're making people laugh! 😄";
      }
      if (lower.includes('where') && (lower.includes('live') || lower.includes('located') || lower.includes('based'))) {
        return "014Boy is based in Embu, Kenya – the heart of smart comedy! 🏞️";
      }
      if (lower.includes('joke') || lower.includes('funny') || lower.includes('utani')) {
        return "Why did the computer go to the doctor? Because it had a virus! 😂 Want another one?";
      }

      // Ultimate fallback – intelligent, not "I don't know"
      return "That's an interesting question! Let me think about it... Here's what I can tell you: I'm 014Boy's AI assistant, and I'm here to help with bookings, social links, or any info about 014Boy. If you have a specific question, feel free to ask again or try the booking form! 🤖";
    }

    // Send message
    sendChat.addEventListener('click', () => {
      const text = chatInput.value.trim();
      if (!text) return;
      // add user message
      chatMessages.innerHTML += `<div class="message user">${text}</div>`;
      chatInput.value = '';
      // simulate thinking
      setTimeout(() => {
        const reply = getBotReply(text);
        chatMessages.innerHTML += `<div class="message bot">${reply}</div>`;
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }, 600);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    });
    chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendChat.click(); });

    // Sticky nav background
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      nav.style.background = window.scrollY > 50 ? 'rgba(10,10,10,0.9)' : 'rgba(10,10,10,0.5)';
    });
  </script>
