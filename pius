  <style>
    /* ---------- RESET & VARIABLES ---------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    :root {
      --bg-dark: #0a0a0a;
      --glass-bg: rgba(20, 20, 20, 0.7);
      --glass-border: rgba(255, 255, 255, 0.08);
      --neon-green: #39FF14;
      --neon-orange: #FF9F1C;
      --text-light: #f0f0f0;
      --text-dim: #b0b0b0;
      --card-bg: rgba(30, 30, 30, 0.5);
      --glow-green: 0 0 15px rgba(57, 255, 20, 0.6);
      --glow-orange: 0 0 15px rgba(255, 159, 28, 0.6);
      --font-primary: 'Inter', sans-serif;
      --font-display: 'Poppins', sans-serif;
      --transition: all 0.3s ease;
    }
    body {
      background-color: var(--bg-dark);
      color: var(--text-light);
      font-family: var(--font-primary);
      line-height: 1.6;
      overflow-x: hidden;
      position: relative;
      -webkit-tap-highlight-color: transparent;
    }
    /* ---------- LOADING SCREEN ---------- */
    #loading-screen {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: var(--bg-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.6s ease, visibility 0.6s;
    }
    .loading-logo {
      font-size: clamp(3rem, 15vw, 4rem);
      font-weight: 800;
      font-family: var(--font-display);
      background: linear-gradient(45deg, var(--neon-green), var(--neon-orange));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: pulseGlow 1.5s infinite alternate;
    }
    @keyframes pulseGlow {
      0% { text-shadow: 0 0 10px var(--neon-green), 0 0 20px var(--neon-orange); }
      100% { text-shadow: 0 0 20px var(--neon-green), 0 0 40px var(--neon-orange); }
    }
    /* ---------- SCROLL PROGRESS BAR ---------- */
    #progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 4px;
      width: 0%;
      background: linear-gradient(90deg, var(--neon-green), var(--neon-orange));
      z-index: 9998;
      transition: width 0.1s;
      box-shadow: var(--glow-green);
    }
    /* ---------- GLASSMORPHISM & UTILS ---------- */
    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px) saturate(180%);
      -webkit-backdrop-filter: blur(12px) saturate(180%);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .neon-text-green {
      color: var(--neon-green);
      text-shadow: var(--glow-green);
    }
    .neon-text-orange {
      color: var(--neon-orange);
      text-shadow: var(--glow-orange);
    }
    .btn-neon {
      background: transparent;
      border: 2px solid var(--neon-green);
      color: var(--neon-green);
      padding: 12px 30px;
      border-radius: 50px;
      font-weight: 600;
      transition: var(--transition);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 1rem;
      backdrop-filter: blur(5px);
      text-decoration: none;
      touch-action: manipulation;
      min-height: 48px; /* better tap target */
    }
    .btn-neon:hover {
      background: var(--neon-green);
      color: #000;
      box-shadow: var(--glow-green);
      transform: translateY(-3px);
    }
    .btn-neon-orange {
      border-color: var(--neon-orange);
      color: var(--neon-orange);
    }
    .btn-neon-orange:hover {
      background: var(--neon-orange);
      color: #000;
      box-shadow: var(--glow-orange);
    }
    /* ---------- STICKY NAV ---------- */
    #navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0.8rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: var(--transition);
      background: rgba(10,10,10,0.5);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--glass-border);
    }
    .nav-logo {
      font-size: 1.6rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--neon-green), var(--neon-orange));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      white-space: nowrap;
    }
    .nav-links {
      display: flex;
      gap: 1.5rem;
    }
    .nav-links a {
      color: var(--text-light);
      text-decoration: none;
      font-weight: 500;
      transition: var(--transition);
      border-bottom: 2px solid transparent;
      padding-bottom: 4px;
      font-size: 1rem;
      touch-action: manipulation;
    }
    .nav-links a:hover {
      color: var(--neon-green);
      border-bottom-color: var(--neon-green);
    }
    /* ---------- HERO SECTION ---------- */
    .hero {
      min-height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem 1rem;
      position: relative;
      overflow: hidden;
    }
    .animated-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: radial-gradient(circle at 30% 50%, rgba(57,255,20,0.1) 0%, transparent 40%),
                  radial-gradient(circle at 70% 60%, rgba(255,159,28,0.1) 0%, transparent 40%);
      animation: moveGradient 15s ease infinite;
      z-index: -1;
    }
    @keyframes moveGradient {
      0% { background-position: 0% 0%; }
      50% { background-position: 100% 100%; }
      100% { background-position: 0% 0%; }
    }
    .profile-img {
      width: 160px;
      height: 160px;
      max-width: 80vw;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid transparent;
      box-shadow: 0 0 25px var(--neon-green), 0 0 45px var(--neon-orange);
      margin-bottom: 1.5rem;
      transition: var(--transition);
    }
    .profile-img:hover {
      transform: scale(1.02);
      box-shadow: 0 0 35px var(--neon-green), 0 0 60px var(--neon-orange);
    }
    .hero h1 {
      font-size: clamp(2.2rem, 10vw, 5rem);
      font-family: var(--font-display);
      font-weight: 800;
      line-height: 1.2;
      word-break: break-word;
    }
    .hero h1 span {
      background: linear-gradient(135deg, var(--neon-green), var(--neon-orange));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-sub {
      font-size: clamp(1.2rem, 4vw, 1.4rem);
      color: var(--text-dim);
      margin: 1rem 0 2rem;
    }
    .hero-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }
    .hero-buttons .btn-neon {
      min-width: 200px;
      flex: 0 1 auto;
    }
    /* social icons row */
    .social-row {
      display: flex;
      gap: 1.8rem;
      justify-content: center;
      flex-wrap: wrap;
      margin: 2rem 0;
    }
    .social-icon {
      font-size: 2.2rem;
      color: var(--text-light);
      transition: var(--transition);
      display: inline-block;
      touch-action: manipulation;
    }
    .social-icon:hover {
      color: var(--neon-green);
      transform: translateY(-5px) scale(1.1);
      text-shadow: var(--glow-green);
    }
    /* floating whatsapp */
    .floating-wa {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #25D366;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.2rem;
      color: white;
      box-shadow: 0 4px 20px rgba(37, 211, 102, 0.5);
      transition: var(--transition);
      z-index: 99;
      text-decoration: none;
      touch-action: manipulation;
    }
    .floating-wa:hover {
      transform: scale(1.1);
      box-shadow: 0 0 25px #25D366;
    }
    /* ---------- SECTIONS ---------- */
    .section {
      padding: 4rem 1rem;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }
    .section-title {
      font-size: clamp(2rem, 6vw, 2.8rem);
      font-weight: 700;
      margin-bottom: 2rem;
      font-family: var(--font-display);
      border-left: 8px solid var(--neon-orange);
      padding-left: 1rem;
    }
    /* about badges */
    .skill-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 2rem;
    }
    .badge {
      background: rgba(57,255,20,0.1);
      border: 1px solid var(--neon-green);
      backdrop-filter: blur(5px);
      padding: 0.6rem 1.2rem;
      border-radius: 40px;
      font-weight: 500;
      transition: var(--transition);
      font-size: 0.9rem;
      touch-action: manipulation;
    }
    .badge:hover {
      background: var(--neon-green);
      color: #000;
      box-shadow: var(--glow-green);
    }
    /* gallery masonry */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      grid-auto-rows: 20px;
      gap: 1rem;
    }
    .gallery-item {
      grid-row-end: span 25;
      border-radius: 18px;
      overflow: hidden;
      cursor: pointer;
      transition: var(--transition);
      background: #1a1a1a;
      border: 1px solid transparent;
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: var(--transition);
    }
    .gallery-item:hover {
      border-color: var(--neon-green);
      box-shadow: var(--glow-green);
      transform: scale(1.02);
    }
    /* lightbox */
    .lightbox {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.95);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 10000;
      padding: 1rem;
    }
    .lightbox.active {
      display: flex;
    }
    .lightbox img {
      max-width: 100%;
      max-height: 80%;
      border-radius: 20px;
      border: 3px solid var(--neon-green);
      object-fit: contain;
    }
    .close-lightbox {
      position: absolute;
      top: 15px; right: 20px;
      font-size: 3rem;
      color: white;
      cursor: pointer;
      touch-action: manipulation;
      z-index: 10001;
    }
    /* booking form & newsletter */
    .booking-form, .newsletter-form, .modal-form {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      max-width: 600px;
      margin: 2rem auto 0;
      width: 100%;
    }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%;
      padding: 1rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      color: white;
      font-size: 1rem;
      backdrop-filter: blur(5px);
      -webkit-appearance: none;
      appearance: none;
    }
    .form-group select {
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='white'><path d='M7 10l5 5 5-5z'/></svg>");
      background-repeat: no-repeat;
      background-position: right 1rem center;
      background-size: 1.5rem;
    }
    .form-group select option {
      background: #1a1a1a;
      color: white;
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      outline: 2px solid var(--neon-green);
    }
    /* modal popup */
    .modal {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(8px);
      align-items: center;
      justify-content: center;
      z-index: 1001;
      padding: 1rem;
    }
    .modal.active {
      display: flex;
    }
    .modal-content {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--neon-green);
      border-radius: 32px;
      padding: 2rem 1.5rem;
      width: 100%;
      max-width: 500px;
      position: relative;
      animation: fadeInUp 0.3s;
    }
    .close-modal {
      position: absolute;
      top: 15px; right: 20px;
      font-size: 2rem;
      color: var(--text-light);
      cursor: pointer;
      touch-action: manipulation;
    }
    /* chat widget - mobile optimized */
    .chat-widget {
      position: fixed;
      bottom: 90px;
      right: 10px;
      width: 90vw;
      max-width: 380px;
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      border: 1px solid var(--neon-orange);
      border-radius: 28px;
      display: none;
      flex-direction: column;
      z-index: 1000;
      box-shadow: 0 10px 40px rgba(0,0,0,0.7);
    }
    @media (min-width: 500px) {
      .chat-widget {
        right: 20px;
        width: 360px;
      }
    }
    .chat-widget.open {
      display: flex;
    }
    .chat-header {
      padding: 1rem 1.2rem;
      border-bottom: 1px solid var(--glass-border);
      font-weight: 600;
      color: var(--neon-green);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .chat-header i {
      font-size: 1.5rem;
      cursor: pointer;
      touch-action: manipulation;
    }
    .chat-messages {
      height: 280px;
      max-height: 40vh;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }
    .message {
      max-width: 85%;
      padding: 0.7rem 1rem;
      border-radius: 20px;
      background: rgba(255,255,255,0.1);
      word-wrap: break-word;
      font-size: 0.95rem;
    }
    .message.bot {
      align-self: flex-start;
      border-bottom-left-radius: 6px;
      background: rgba(57,255,20,0.15);
      border: 1px solid var(--neon-green);
    }
    .message.user {
      align-self: flex-end;
      border-bottom-right-radius: 6px;
      background: rgba(255,159,28,0.15);
      border: 1px solid var(--neon-orange);
    }
    .chat-input-area {
      display: flex;
      padding: 0.8rem;
      gap: 0.5rem;
      border-top: 1px solid var(--glass-border);
    }
    .chat-input-area input {
      flex: 1;
      padding: 0.8rem 1rem;
      border-radius: 40px;
      border: none;
      background: rgba(0,0,0,0.4);
      color: white;
      font-size: 1rem;
      min-height: 44px;
    }
    .chat-send {
      background: var(--neon-green);
      border: none;
      border-radius: 50%;
      width: 48px;
      height: 48px;
      color: black;
      font-size: 1.3rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      touch-action: manipulation;
      flex-shrink: 0;
    }
    .chat-toggle {
      position: fixed;
      bottom: 90px;
      right: 20px;
      background: var(--neon-orange);
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: black;
      cursor: pointer;
      box-shadow: var(--glow-orange);
      transition: var(--transition);
      z-index: 999;
      touch-action: manipulation;
    }
    /* footer */
    .footer {
      background: rgba(0,0,0,0.8);
      backdrop-filter: blur(12px);
      padding: 2.5rem 1rem 1.5rem;
      border-top: 1px solid var(--glass-border);
    }
    .footer-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }
    .footer-bottom {
      text-align: center;
      color: var(--text-dim);
      font-size: 0.9rem;
    }
    /* animations */
    .fade-in {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
    /* extra touch optimizations */
    button, a, .btn-neon, .social-icon, .chat-toggle, .floating-wa, .close-modal, .close-lightbox, .gallery-item, .badge {
      touch-action: manipulation;
    }
    /* small screens adjustments */
    @media (max-width: 480px) {
      .hero-buttons .btn-neon {
        min-width: 100%;
      }
      .nav-links {
        gap: 1rem;
      }
      .nav-links a {
        font-size: 0.9rem;
      }
      .section {
        padding: 3rem 0.8rem;
      }
      .profile-img {
        width: 140px;
        height: 140px;
      }
      .social-row {
        gap: 1.2rem;
      }
      .social-icon {
        font-size: 1.8rem;
      }
      .chat-toggle {
        bottom: 80px;
        right: 15px;
        width: 50px;
        height: 50px;
        font-size: 1.8rem;
      }
      .floating-wa {
        bottom: 15px;
        right: 15px;
        width: 50px;
        height: 50px;
        font-size: 2rem;
      }
    }
  </style>
</head>
